# Spider 配置文件
# 复制此文件为 .env 并根据需要修改

# 基础配置
SPIDER_LOG_LEVEL=INFO
SPIDER_TEMPLATE_DIR=templates
SPIDER_OUTPUT_DIR=output
SPIDER_MAX_CONCURRENT_TASKS=5

# HTTP 配置
SPIDER_HTTP_REQUEST_TIMEOUT=30.0
SPIDER_HTTP_DOWNLOAD_TIMEOUT=300.0
SPIDER_HTTP_MAX_RETRIES=3
SPIDER_HTTP_RETRY_BACKOFF=2.0
SPIDER_HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SPIDER_HTTP_PROXY=
# 如果遇到SSL错误，设置为false
SPIDER_HTTP_VERIFY_SSL=true

# 下载配置
SPIDER_DOWNLOAD_CHUNK_SIZE=8192
SPIDER_DOWNLOAD_MAX_FILE_SIZE=524288000

# MongoDB 配置
SPIDER_DB_URL=
SPIDER_DB_NAME=

# Redis 配置
SPIDER_REDIS_URL=

# MinIO 配置
SPIDER_MINIO_ENDPOINT=
SPIDER_MINIO_ACCESS_KEY=
SPIDER_MINIO_SECRET_KEY=
SPIDER_MINIO_BUCKET=
SPIDER_MINIO_SECURE=false

# Kafka 配置
SPIDER_KAFKA_BROKERS=
SPIDER_KAFKA_TOPIC=
SPIDER_KAFKA_CLIENT_ID=
SPIDER_KAFKA_ENABLE_IDEMPOTENCE=true

# 反爬智能层配置
SPIDER_ANTI_CRAWL_ENABLED=false
SPIDER_PROXY_POOL_FILE=
SPIDER_PROXY_POOL_API_URL=
SPIDER_PROXY_ROTATION=round_robin
SPIDER_PROXY_HEALTH_CHECK_URL=https://httpbin.org/ip
SPIDER_PROXY_MAX_FAILURES=3
SPIDER_REQUEST_DELAY_MIN=1.0
SPIDER_REQUEST_DELAY_MAX=3.0
SPIDER_DOMAIN_RATE_LIMIT={}
SPIDER_USER_AGENT_POOL_FILE=
SPIDER_REFERER_ENABLED=false
SPIDER_COOKIE_POOL_FILE=
SPIDER_IDENTITY_ROTATION_INTERVAL=0

# 去重配置
SPIDER_DEDUP_ENABLED=false
SPIDER_DEDUP_KEY_PREFIX=spider:dedup
SPIDER_BLOOM_FILTER_ENABLED=false
SPIDER_BLOOM_FILTER_CAPACITY=1000000
SPIDER_BLOOM_FILTER_ERROR_RATE=0.001
SPIDER_BLOOM_FILTER_KEY_PREFIX=spider:bloom
SPIDER_INCREMENTAL_MODE=false

# 调度器配置
SPIDER_SCHEDULER_ENABLED=false
SPIDER_RATE_LIMIT_ENABLED=false
SPIDER_DOMAIN_RATE_LIMIT_CONFIG={}
SPIDER_FALLBACK_ENABLED=false
SPIDER_FALLBACK_MAX_PROXY_FAILURES=5
SPIDER_FALLBACK_COOLDOWN_SECONDS=300

# 模板引擎配置
SPIDER_JINJA2_ENABLED=false
SPIDER_CONDITIONAL_FIELDS_ENABLED=false
SPIDER_PRE_HOOKS_ENABLED=false

# Postgres ETL 配置
SPIDER_PG_URL=postgresql+asyncpg://postgres:postgres@localhost:32775/spider_etl
SPIDER_PG_POOL_MIN=2
SPIDER_PG_POOL_MAX=10

# ETL Kafka Topics
SPIDER_ETL_RAW_TOPIC=
SPIDER_ETL_RDS_TOPIC=
SPIDER_ETL_ODS_TOPIC=
SPIDER_ETL_ADS_TOPIC=
SPIDER_ETL_TASK_TOPIC=
SPIDER_ETL_DWD_TOPIC=
SPIDER_ETL_GRAPH_TOPIC=
SPIDER_ETL_DWS_TOPIC=
SPIDER_ETL_DIM_TOPIC=

# ETL Consumer Groups
SPIDER_ETL_RDS_CONSUMER_GROUP=spider-rds-group
SPIDER_ETL_ODS_CONSUMER_GROUP=spider-ods-group
SPIDER_ETL_ADS_CONSUMER_GROUP=spider-ads-group
SPIDER_ETL_TASK_CONSUMER_GROUP=spider-task-group
SPIDER_ETL_DWD_CONSUMER_GROUP=spider-dwd-group
SPIDER_ETL_GRAPH_CONSUMER_GROUP=spider-graph-group
SPIDER_ETL_DWS_CONSUMER_GROUP=spider-dws-group
SPIDER_ETL_DIM_CONSUMER_GROUP=spider-dim-group
