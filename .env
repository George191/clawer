# Spider 配置文件
# 为了解决SSL错误，先禁用SSL验证
SPIDER_HTTP_VERIFY_SSL=false

# 其他配置使用默认值
SPIDER_LOG_LEVEL=INFO
SPIDER_TEMPLATE_DIR=templates
SPIDER_OUTPUT_DIR=output
SPIDER_MAX_CONCURRENT_TASKS=30

# ── 反爬功能和代理池（全局默认）─────────────────
# 各任务模板可在 YAML 中设置 anti_crawl_enabled: true/false 覆盖此全局值。
# 优先级：模板 YAML > 此全局配置 > False（默认关闭）
SPIDER_ANTI_CRAWL_ENABLED=true

# ── 隧道代理（优先于代理池） ──────────────────
# 格式: http://user:pass@host:port
# SPIDER_TUNNEL_PROXY_URL=http://1914550400@qq.com:Qwerty123458@47.111.161.57:8889
# SPIDER_TUNNEL_PROXY_URL=http://1914550400@qq.com:Qwerty123458@https://www.viewturbo.com/zh/download

# 代理池API配置 - 使用您提供的API（隧道代理配置后此配置无效）
SPIDER_PROXY_POOL_API_URL=http://www.zdopen.com/FreeProxy/Get/?app_id=202606031256055320&akey=5c8b84ddbf22acbc&dalu=0&return_type=3

# 代理轮换策略 - round_robin 或 random
SPIDER_PROXY_ROTATION=round_robin

# 代理健康检查URL
SPIDER_PROXY_HEALTH_CHECK_URL=https://httpbin.org/ip

# 代理最大失败次数 - 超过后会被摘除
SPIDER_PROXY_MAX_FAILURES=3

# 请求延迟配置（秒）
SPIDER_REQUEST_DELAY_MIN=0.0
SPIDER_REQUEST_DELAY_MAX=3.0


SPIDER_HTTP_REQUEST_TIMEOUT=30.0
SPIDER_HTTP_DOWNLOAD_TIMEOUT=300.0
SPIDER_HTTP_MAX_RETRIES=3
SPIDER_HTTP_RETRY_BACKOFF=2.0
SPIDER_HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SPIDER_HTTP_VERIFY_SSL=false

SPIDER_DOWNLOAD_CHUNK_SIZE=8192
SPIDER_DOWNLOAD_MAX_FILE_SIZE=524288000

SPIDER_DB_URL=mongodb://localhost:32796
SPIDER_DB_NAME=raw_data
SPIDER_REDIS_URL=redis://localhost:32769/0

SPIDER_MINIO_ENDPOINT=10.10.0.200:9000
SPIDER_MINIO_ACCESS_KEY=minioadmin
SPIDER_MINIO_SECRET_KEY=minioadmin
SPIDER_MINIO_BUCKET=internal
SPIDER_MINIO_SECURE=false

SPIDER_KAFKA_BROKERS=localhost:32792
SPIDER_KAFKA_TOPIC=spider-crawler
SPIDER_KAFKA_CLIENT_ID=spider-producer

SPIDER_DEDUP_ENABLED=true
SPIDER_INCREMENTAL_MODE=true

# ── Postgres ETL Pipeline ──────────────────────────────────────
SPIDER_PG_USER=postgres
SPIDER_PG_PASS=postgres
SPIDER_PG_DB=ts_data
SPIDER_PG_URL=postgresql+asyncpg://postgres:postgres@localhost:32771/ts_data
SPIDER_PGADMIN_EMAIL=admin@spider.local
SPIDER_PGADMIN_PASS=admin

# -- ETL Kafka Topics (internal pipeline) --
SPIDER_ETL_RAW_TOPIC=spider-crawler
SPIDER_ETL_RDS_TOPIC=etl-rds
SPIDER_ETL_ODS_TOPIC=etl-ods
SPIDER_ETL_ADS_TOPIC=etl-ads
SPIDER_ETL_TASK_TOPIC=etl-task
SPIDER_ETL_DIM_TOPIC=etl-dim
SPIDER_ETL_DWD_TOPIC=etl-dwd
SPIDER_ETL_DWS_TOPIC=etl-dws
SPIDER_ETL_GRAPH_TOPIC=etl-graph


SPIDER_ETL_RDS_CONSUMER_GROUP=etl-rds-group
SPIDER_ETL_ODS_CONSUMER_GROUP=etl-ods-group
SPIDER_ETL_ADS_CONSUMER_GROUP=etl-ads-group
SPIDER_ETL_TASK_CONSUMER_GROUP=etl-task-group
SPIDER_ETL_DIM_CONSUMER_GROUP=etl-dim-group
SPIDER_ETL_DWD_CONSUMER_GROUP=etl-dwd-group
SPIDER_ETL_DWS_CONSUMER_GROUP=etl-dws-group
SPIDER_ETL_GRAPH_CONSUMER_GROUP=etl-graph-group
